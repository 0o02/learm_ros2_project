<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="LeArm">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import LeArm urdf file -->
    <xacro:include filename="$(find learm_description)/urdf/learm.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="LeArm.ros2_control.xacro" />


    <xacro:LeArm_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
