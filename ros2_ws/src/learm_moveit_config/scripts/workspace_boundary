#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
基于蒙特卡洛采样 + 碰撞检测 + 凸包算法的工作空间立体边界生成器
- 稳定无参数，100% 生成封闭网格
- 支持点云缓存，配置变化自动重采样
- 在 RViz 中显示半透明立体区域
"""

import rclpy
from rclpy.node import Node
from sensor_msgs.msg import JointState
from geometry_msgs.msg import Point
from visualization_msgs.msg import Marker
from moveit_msgs.srv import GetStateValidity
from moveit_msgs.msg import RobotState
from tf2_ros import Buffer, TransformListener
import random
import numpy as np
import os
import pickle
import hashlib
import json
from scipy.spatial import ConvexHull   # 唯一需要的空间算法

class WorkspaceBoundary(Node):
    def __init__(self):
        super().__init__('workspace_boundary')
        self.js_pub = self.create_publisher(JointState, '/joint_states', 10)
        self.marker_pub = self.create_publisher(Marker, '/workspace_marker', 10)

        self.tf_buffer = Buffer()
        self.tf_listener = TransformListener(self.tf_buffer, self)

        # 碰撞检测服务
        self.state_validity_client = self.create_client(GetStateValidity, '/check_state_validity')
        self.get_logger().info('等待 /check_state_validity 服务...')
        if not self.state_validity_client.wait_for_service(timeout_sec=5.0):
            self.get_logger().error('碰撞检测服务不可用，请确认 move_group 已启动')
        else:
            self.get_logger().info('碰撞检测服务已连接')

        self.joint_names = [
            'shoulder_pan', 'shoulder_lift', 'elbow',
            'wrist_flex', 'wrist_roll'
        ]
        self.joint_limits = {
            'shoulder_pan':  (-2.10, 1.04),
            'shoulder_lift': (-1.57, 1.57),
            'elbow':         (-1.55, 1.60),
            'wrist_flex':    (-1.62, 1.52),
            'wrist_roll':    (-3.05, 0.096)
        }

        self.num_samples = 10000
        self.z_min = 0.05
        self.z_max = 0.40
        self.y_max = 0.30

        # 配置哈希，参数变化时自动重采样
        config_dict = {
            'joint_limits': self.joint_limits,
            'num_samples': self.num_samples,
            'z_min': self.z_min, 'z_max': self.z_max, 'y_max': self.y_max
        }
        self.config_hash = hashlib.md5(json.dumps(config_dict, sort_keys=True).encode()).hexdigest()
        self.cache_file = os.path.expanduser('~/workspace_points_cache.pkl')
        self.hash_file = self.cache_file + '.hash'

        need_resample = True
        if os.path.exists(self.cache_file) and os.path.exists(self.hash_file):
            with open(self.hash_file, 'r') as f:
                old_hash = f.read().strip()
            if old_hash == self.config_hash:
                need_resample = False
                self.get_logger().info('配置未变化，加载缓存点集')
            else:
                self.get_logger().info('配置已变化，将重新采样')
                os.remove(self.cache_file)

        if not need_resample:
            self.load_cache_and_publish()
        else:
            self.get_logger().info(f'开始蒙特卡洛采样（含碰撞检测），目标点数: {self.num_samples}')
            self.collected_points = []
            self.timer = self.create_timer(0.05, self.sample_step)

    def sample_step(self):
        if len(self.collected_points) >= self.num_samples:
            self.save_cache()
            self.publish_convex_hull()
            self.timer.cancel()
            return

        positions = [random.uniform(*self.joint_limits[name]) for name in self.joint_names]
        js = JointState()
        js.header.stamp = self.get_clock().now().to_msg()
        js.name = self.joint_names
        js.position = positions
        self.js_pub.publish(js)
        self.get_clock().sleep_for(rclpy.duration.Duration(seconds=0.01))

        try:
            t = self.tf_buffer.lookup_transform('base_link', 'hand_link', rclpy.time.Time())
            p = t.transform.translation
        except Exception:
            return

        if not (self.z_min <= p.z <= self.z_max and abs(p.y) <= self.y_max):
            return

        if self.state_validity_client.service_is_ready():
            rs = RobotState()
            rs.joint_state.name = self.joint_names
            rs.joint_state.position = positions

            req = GetStateValidity.Request()
            req.robot_state = rs
            req.group_name = 'arm_group'
            req.attached_collision_objects = []

            future = self.state_validity_client.call_async(req)
            rclpy.spin_until_future_complete(self, future, timeout_sec=0.1)
            if future.result() is not None and future.result().valid:
                self.collected_points.append([p.x, p.y, p.z])
                if len(self.collected_points) % 500 == 0:
                    self.get_logger().info(f'已采集 {len(self.collected_points)} 个有效点')
        else:
            self.get_logger().warn('碰撞检测服务不可用，使用几何过滤', throttle_duration_sec=5.0)
            self.collected_points.append([p.x, p.y, p.z])

    def save_cache(self):
        with open(self.cache_file, 'wb') as f:
            pickle.dump(self.collected_points, f)
        with open(self.hash_file, 'w') as f:
            f.write(self.config_hash)
        self.get_logger().info(f'点集已缓存至 {self.cache_file}')

    def load_cache_and_publish(self):
        with open(self.cache_file, 'rb') as f:
            self.collected_points = pickle.load(f)
        self.get_logger().info(f'已加载 {len(self.collected_points)} 个缓存点')
        self.publish_convex_hull()

    def publish_convex_hull(self):
        if len(self.collected_points) < 4:
            self.get_logger().error("点数不足，无法生成凸包")
            return

        pts = np.array(self.collected_points)
        hull = ConvexHull(pts)

        marker = Marker()
        marker.header.frame_id = "base_link"
        marker.header.stamp = self.get_clock().now().to_msg()
        marker.ns = "workspace_hull"
        marker.id = 0
        marker.type = Marker.TRIANGLE_LIST
        marker.action = Marker.ADD
        marker.scale.x = 1.0
        marker.scale.y = 1.0
        marker.scale.z = 1.0
        marker.color.r = 1.0
        marker.color.g = 0.5
        marker.color.b = 0.0
        marker.color.a = 0.35

        for simplex in hull.simplices:
            for idx in simplex:
                p = pts[idx]
                marker.points.append(Point(x=p[0], y=p[1], z=p[2]))

        self.marker_pub.publish(marker)
        self.get_logger().info(f"凸包网格已发布，共 {len(hull.simplices)} 个三角形")
        self.get_logger().info(f"工作空间范围: X[{pts[:,0].min():.3f}, {pts[:,0].max():.3f}] "
                               f"Y[{pts[:,1].min():.3f}, {pts[:,1].max():.3f}] "
                               f"Z[{pts[:,2].min():.3f}, {pts[:,2].max():.3f}]")

def main(args=None):
    rclpy.init(args=args)
    node = WorkspaceBoundary()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
